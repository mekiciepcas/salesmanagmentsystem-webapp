{
  "name": "pricing-pro",
  "version": "1.0.0",
  "description": "Professional Pricing Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "web": "node src/server/server.js",
    "server": "node src/server/server.js",
    "dev:electron": "concurrently \"npm run server\" \"npm start\"",
    "dev:web": "node src/server/server.js",
    "dev": "node src/server/server.js",
    "gate:config": "node scripts/ci/config-gate.js",
    "gate:secrets": "node scripts/ci/secrets-gate.js",
    "gate:dependency": "node scripts/ci/dependency-gate.js",
    "gate:injection": "node scripts/ci/injection-gate.js",
    "gate:all": "npm run gate:config && npm run gate:secrets && npm run gate:dependency && npm run gate:injection",
    "test:dc-choke": "node scripts/test-dc-choke-catalog.js",
    "web:legacy": "node server-standalone.js",
    "debug": "electron . --inspect-brk --enable-logging",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release-major": "npm version major && electron-builder",
    "release-minor": "npm version minor && electron-builder",
    "release-patch": "npm version patch && electron-builder",
    "publish": "electron-builder -p always"
  },
  "keywords": [
    "electron",
    "pricing",
    "desktop-app"
  ],
  "author": "EPC",
  "license": "ISC",
  "build": {
    "extraResources": [
      {
        "from": "credentials.json",
        "to": "credentials.json"
      }
    ]
  },
  "dependencies": {
    "axios": "^1.10.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "docxtemplater": "^3.60.2",
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.6.2",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "fs-extra": "^11.2.0",
    "jsonwebtoken": "^9.0.2",
    "google-auth-library": "^9.15.0",
    "jspdf": "^3.0.1",
    "jspdf-autotable": "^5.0.2",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.6.7",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.11.3",
    "pg-promise": "^11.13.0",
    "pizzip": "^3.1.8",
    "qrcode": "^1.5.4",
    "response-time": "^2.3.2",
    "winston": "^3.11.0",
    "ws": "^8.18.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^27.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.3",
    "prettier": "^3.6.2"
  }
}
