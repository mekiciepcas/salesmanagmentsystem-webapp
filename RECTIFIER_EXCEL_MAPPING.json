  "calculationFormulas": {
    "transformerPower": {
      "formula": "(outputCurrent * outputVoltage) / (efficiency * powerFactor)",
      "efficiency": {
        "3": 0.9,
        "1": 0.8
      },
      "powerFactor": {
        "3": 0.8,
        "1": 0.7
      }
    },
    "inputCurrent": {
      "formula": "transformerPower / (inputVoltageWithTolerance * Math.sqrt(inputPhase))",
      "inputVoltageWithTolerance": {
        "formula": "inputVoltage * (1 - voltageTolerance)"
      }
    },
    "secondaryVoltage": {
      "formula": "inputPhase === 3 ? floatVoltage : boostVoltage"
    },
    "leakageInductance": {
      "steps": [
        {
          "step": 1,
          "description": "V hesaplama",
          "formula": "V = secondaryVoltage * 0.04",
          "condition": "if inputPhase === 3: V = V / 1.732"
        },
        {
          "step": 2,
          "description": "I hesaplama",
          "formula": "I = transformerPower / (secondaryVoltage * Math.sqrt(inputPhase))"
        },
        {
          "step": 3,
          "description": "XL hesaplama",
          "formula": "XL = V / I"
        },
        {
          "step": 4,
          "description": "L hesaplama",
          "formula": "L = XL / (2 * Math.PI * systemFrequency)"
        }
      ]
    },
    "cutoffFrequency": {
      "formula": "fkesme = 1 / (2 * Math.PI * Math.sqrt(L * C * capacitorCount))",
      "targetValues": {
        "B6C": "(systemFrequency * 6) / 10",
        "B12C": "(systemFrequency * 12) / 10",
        "B2H": "(systemFrequency * 2) / 3"
      }
    },
    "dropperModuleCount": {
      "formula": "voltageDrop / 1.5",
      "perStage": true
    },
    "dropperDiodeCurrent": {
      "formula": "outputCurrent * 1.5"
    },
    "dropperRelayCurrent": {
      "formula": "outputCurrent"
    },
    "lvdRelayCurrent": {
      "formula": "outputCurrent * 1.2"
    },
    "voltmeterRange": {
      "formula": "voltage * 1.2",
      "voltageSource": {
        "giriş": "inputVoltageNominal",
        "çıkış": "outputVoltage",
        "akü": "batteryVoltage"
      }
    }
  },
